#!/usr/bin/env ruby
# frozen_string_literal: true

require "roda"
require "dotenv"
require_relative "../lib/room_service/boot"
Dotenv.load(File.expand_path("../lib.env", __dir__))

Async do
  client = RoomService::Clients::JanusClient.new
  rooms = client.list_janus_rooms

  if rooms.empty?
    puts "No active rooms to destroy."
    exit 0
  end

  rooms.each do |room|
    room_id = room["room"]
    client.destroy_janus_room(room_id)
    puts "Destroyed room #{room_id}"
  end
end
